# Local development defaults
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_SESSION_COOKIE_DOMAIN=
DJANGO_CSRF_COOKIE_DOMAIN=
DJANGO_SESSION_COOKIE_AGE=7200
DJANGO_SESSION_SAVE_EVERY_REQUEST=true
DATABASE_URL=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional one-time Render admin bootstrap
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_RESET_PASSWORD=false

# Optional PDF font override
COREACTA_PDF_FONT=
